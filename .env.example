# ArtBridge environment variables.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# Prisma / PostgreSQL (Neon, Supabase, or local)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=

# Mock auth: email of the seeded user to impersonate server-side (demo only).
# Leave empty to disable server-side current user. Example: creator@artbridge.demo
DEMO_USER_EMAIL=

# ── Optional (uncomment when the feature is enabled) ──

# AI recommendation (OpenAI JSON schema). If empty, deterministic mock fallback is used.
OPENAI_API_KEY=

# Auth.js (when migrating off mock auth)
# AUTH_SECRET=

# Storage (Cloudinary / Supabase Storage) — only if image upload is enabled.
# CLOUDINARY_URL=
# SUPABASE_STORAGE_URL=
